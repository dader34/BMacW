# Vendored data. EDIABAS/Ecu and EC-APPS are BMW proprietary, committed via Git LFS.
# The app only reads EDIABAS/Ecu, so the Windows Bin/Hardware are excluded.
vendor/ms45-flasher/.git/
vendor/ediabaslib-src/
vendor/BMW Standard Tools/
vendor/EDIABAS/Bin/
vendor/EDIABAS/Hardware/
vendor/**/*.bak
# .NET build output
bin/
obj/
*.user
# Node / Electron
node_modules/
app/server-dist/

# Mac
.DS_Store

# Release builds
dist-release/
app/dist-release/

# Derived/proprietary data: INPA-mined layouts, RE anchors tied to a flash dump,
# pasted reference lists. Generated locally from vendor data; not shipped.
data/

# Filled workflow scripts (contain large embedded ECU lists)
tools/*.filled.mjs

# Python bytecode
__pycache__/
*.pyc

# Workflow scripts (throwaway, contain absolute paths)
tools/*.mjs
