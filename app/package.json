{
  "name": "bmacw",
  "productName": "BMacW",
  "version": "0.1.5",
  "description": "BMacW, native macOS BMW diagnostics (Chromium shell over the EDIABAS engine)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:server": "rm -rf ./server-dist && dotnet publish ../src/InpaMac.Server -c Release -r osx-arm64 --self-contained -p:PublishSingleFile=true -o ./server-dist",
    "build:faultdb": "node ../scripts/build-faultdb.mjs",
    "check:faults": "node ../scripts/check-faults.mjs",
    "dist": "npm run build:server && npm run build:faultdb && npx electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0"
  }
}
