ENTRY=D50M57,DDE5.0 for M57,
ENTRY=ME72,ME7.2 for M62 MJ 99,
ENTRY=ME9_N62,ME9.2 for N62,
ENTRY=MS420,MS42 for M52,
ENTRY=MS430,MS43 for M54,
ENTRY=CARB,Carb-Interface,

[ROOT_GETRIEBE]
DESCRIPTION=Transmission
ENTRY=gsds2,GS8.xx,
ENTRY=GS19,Gearbox Control Module GS19,
ENTRY=vgsg83,DXC Gearbox VGSG,

[ROOT_FAHRWERK]
