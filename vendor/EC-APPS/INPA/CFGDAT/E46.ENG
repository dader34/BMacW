[ROOT]
DESCRIPTION=E46
ENTRY=EXX,Functional jobs,

[ROOT_MOTOR]
DESCRIPTION=Engine
ENTRY=DDE40,DDE 4.0 for M57,
ENTRY=D50M47,DDE 5.0 for M47 new,
ENTRY=D50M57,DDE 5.0 for M57 new,
ENTRY=EKP_DS2,Fuel pump EKP,
ENTRY=BMS46,BMS46 for M43,
ENTRY=ME9_4N,ME9.2 for N42/N45,
ENTRY=ME9NG4TU,ME9.2/MEV9 for N46,
ENTRY=MS420,MS42 for M52,
ENTRY=MS430,MS43 for M54,
ENTRY=MS450,MS45.1 for M54,
ENTRY=MSS54M3,MSS54 for S54,
ENTRY=CARB,CARB,

[ROOT_GETRIEBE]
DESCRIPTION=Transmission
ENTRY=gsds2,GS20/GS8.xx for GM or ZF,
ENTRY=gs30,Sequential Gearbox SSG,
ENTRY=smg2,SMG2 for M3,

[ROOT_FAHRWERK]
DESCRIPTION=Chassis
