[ROOT]
DESCRIPTION=E85
ENTRY=E85,IDENT / read-clear error/info memory E85,

[ROOT_MOTOR]
DESCRIPTION=Engine
ENTRY=ME9NG4TU,MEV9 for N46,
ENTRY=MS450,MS45.0 for M54,
ENTRY=MSS70,MSS70 for S54,
ENTRY=MSV70,MSV70.0 for N52,
ENTRY=EKP2DS2,Fuel pump EKP,

[ROOT_GETRIEBE]
DESCRIPTION=Transmission
ENTRY=gsds2,GS8.xx/GS20,
ENTRY=gs30,Sequential Gearbox SSG,

[ROOT_FAHRWERK]
DESCRIPTION=Chassis
ENTRY=dscmk60,DSC MK60,
ENTRY=eps_e85,Electronic power steering,
ENTRY=lws5,Steering angle sensor,
ENTRY=RDC_53,Tire Pressure Monitoring,

[ROOT_KAROSSERIE]
DESCRIPTION=Body
ENTRY=ACSM,Airbag,
ENTRY=cvm_IV,Convertible soft top module CVM IV,
ENTRY=ews,Electronic vehicle immobilization EWS,
ENTRY=zke5,Central body module,
ENTRY=ihkx85,Air conditioning HS/IHKS/IHKA,
ENTRY=kombi,Instrument cluster,
ENTRY=lsz,Light switch center LSZ,
ENTRY=pdc,Park distance control PDC,
ENTRY=rls_ds2,Rain and light sensor RLS,
ENTRY=sm46,Seatmemory,
ENTRY=szm,Middle console center switch,

[ROOT_SICHERHEITSMODULE]
DESCRIPTION=Safety modules
ENTRY=SIM,Safety Information Module,
ENTRY=STVL,Satellite door front left,
ENTRY=STVR,Satellite door front right,
ENTRY=SBSL,Satellite B column left,
ENTRY=SBSR,Satellite B column right,

[ROOT_KOMMUNIKATION]
DESCRIPTION=Communication systems
ENTRY=CID_85,On board monitor CID,
ENTRY=CDC,CD changer,
ENTRY=radio,MIR,
ENTRY=dsp,DSP carver,
ENTRY=navi,Navigation computer,
ENTRY=nav_jap,Navigation computer Japan,
ENTRY=radio,Radio,
ENTRY=telefon,Telephone,
ENTRY=videomod,Video module,

